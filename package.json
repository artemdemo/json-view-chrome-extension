{
  "name": "json-view-chrome-extension",
  "description": "Pretty-print browser-rendered application/json responses.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "npm run dev -w packages/extension",
    "build": "npm run build -w packages/extension",
    "lint": "biome check . && bun run lint:versions",
    "lint:fix": "biome check . --fix && bun run lint:versions",
    "lint:versions": "syncpack lint --dependency-types prod,dev",
    "typecheck": "npm run typecheck -ws"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "syncpack": "^15.0.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
