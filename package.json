{
  "name": "json-view-chrome-extension",
  "description": "Pretty-print browser-rendered application/json responses.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "npm run dev -w packages/extension",
    "build": "npm run build -w packages/extension",
    "lint": "biome check . && npm run lint:versions",
    "lint:fix": "biome check . --fix && npm run lint:versions",
    "lint:versions": "syncpack lint --dependency-types prod,dev",
    "typecheck": "npm run typecheck -ws"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "syncpack": "^15.0.0"
  }
}
