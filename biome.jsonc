{
  "files": {
    "includes": [
      "packages/*/src/**/*.ts",
      "packages/extension/entrypoints/**/*.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "includes": ["**", "!test/**"],
    "rules": {
      "nursery": {
        "useExhaustiveSwitchCases": "error"
      }
    }
  }
}
